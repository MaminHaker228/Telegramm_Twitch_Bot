<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F4F7FB" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#EEF4FB" />
    <SolidColorBrush x:Key="SurfaceSoftBrush" Color="#F8FBFF" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextBrush" Color="#102033" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#334155" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
    <SolidColorBrush x:Key="BorderBrush" Color="#D8E3F0" />
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#E7EEF7" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="AccentStrongBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#DBEAFE" />
    <SolidColorBrush x:Key="AccentContrastBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A" />
    <SolidColorBrush x:Key="WarningBrush" Color="#EA580C" />
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="HeroBrushStart" Color="#F8FBFF" />
    <SolidColorBrush x:Key="HeroBrushEnd" Color="#E8F0FF" />
    <SolidColorBrush x:Key="HeroAccentBrush" Color="#BFDBFE" />
    <SolidColorBrush x:Key="DecorativeBrush" Color="#BFDBFE" />
    <SolidColorBrush x:Key="LogBackgroundBrush" Color="#F8FAFC" />
    <LinearGradientBrush x:Key="HeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F8FBFF" Offset="0" />
        <GradientStop Color="#E8F0FF" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
