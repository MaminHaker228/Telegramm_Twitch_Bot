<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#09111F" />
    <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#050B16" Offset="0" />
        <GradientStop Color="#0A1222" Offset="0.48" />
        <GradientStop Color="#0C1629" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#101A2F" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#16243C" />
    <SolidColorBrush x:Key="SurfaceSoftBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#14223A" />
    <SolidColorBrush x:Key="TextBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#D6E0EA" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="BorderBrush" Color="#24324C" />
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#1A2941" />
    <SolidColorBrush x:Key="AccentBrush" Color="#F97316" />
    <SolidColorBrush x:Key="AccentStrongBrush" Color="#EA580C" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#3A2315" />
    <SolidColorBrush x:Key="AccentContrastBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FB923C" />
    <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />
    <SolidColorBrush x:Key="HeroBrushStart" Color="#14233C" />
    <SolidColorBrush x:Key="HeroBrushEnd" Color="#0D172A" />
    <SolidColorBrush x:Key="HeroAccentBrush" Color="#36241A" />
    <SolidColorBrush x:Key="DecorativeBrush" Color="#25192C" />
    <SolidColorBrush x:Key="LogBackgroundBrush" Color="#0B1325" />
    <LinearGradientBrush x:Key="HeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#14233C" Offset="0" />
        <GradientStop Color="#0D172A" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
